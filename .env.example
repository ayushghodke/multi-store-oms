# Copy this to .env and fill in your Supabase credentials
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project:your-password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# The Vercel URL of your deployed frontend (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Server port (Railway sets this automatically)
PORT=3001
